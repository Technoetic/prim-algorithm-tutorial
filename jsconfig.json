{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.js", "tests/**/*.js"],
  "exclude": ["node_modules", "dist", "step_archive"]
}
